#!/usr/bin/env ys-0

# Detect functions/patterns documented in session notes
# but missing from SKILL.md.

# Words too generic or too context-specific to report.
noise =: qw(
  a b c d e f g h i j k l m n o r s t v w x y z
  fn if do in is or of on as at by it to up us we
  the and for not but let its key val use has nil
  set get map add sub put run end all was any tab
  one two may coll arg args body text line word ws
  name path file list then else true false data
  result acc idx cnt method pattern letter steps
  full-match group1 identity fnil conj update
  arg1 arg2 word1 word2 line1 line2 n-1 c2
  fib palindrome? fizzbuzz collatz-step
  fn-body say1 dec get+
  call-api get-token prompt
  )

defn main():
  root =: ENV.YS_SKILL_ROOT ||| '../../ys-skill'
  skill =: read("$root/skills/yamlscript/SKILL.md")
  files =: fs/glob('sessions/*.yaml'):sort
  gaps =: atom({})

  each f files:
    data =: f:read:yaml/load
    each entry data:
      notes =: entry.notes
      id =: entry.id
      when notes:
        tokens =:
          notes.re-seq(/`([^`]+)`/)
            .map(second)
        each token tokens:
          names =: extract-fns(token)
          each name names:
            when-not name.in?(skill):
              swap! gaps:
                fn(m):
                  update m name:
                    \(conj (_1 ||| []) id)

  result =: deref(gaps)
  if result.!:
    say: 'SKILL.md is up to date with all session notes.'
    else:
      say: "Functions in sessions but not in SKILL.md:"
      each [name ids] result:sort:
        say: "  $name  ($(ids:distinct:joins))"

defn extract-fns(token):
  re1 =: /(?:^|[.:])([a-z][-a-z0-9]*[?!+]*)(?:\(|$)/
  re2 =: /^([a-z][-a-z0-9]*[?!+]*)$/
  seconds =: map + second
  calls =: token.re-seq(re1):seconds
  standalones =: token.re-seq(re2):seconds
  calls ||| standalones:
    .filter(fn-name?)
    .remove(\(_.in?(noise)))

defn fn-name?(s):
  and:
    (s.# >= 2)
    (s =~ /[a-z][-a-z0-9]*[?!+]*/)
    (s !~ /.*\d$/)
