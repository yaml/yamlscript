#!/usr/bin/env ys-0

defn main(source wrapper):
  code =: source:read
  ys-bin =: RUN.yspath
  rc =: sh("$ys-bin -c $source")

  when rc.exit != 0:
    die: "Error:\n$(rc.err)"

  code =: rc.out
  code =: code.replace(/\n\(apply main ARGS\)\n\z/)

  print:
    str/replace-first wrapper:read /;;CODE;;/:
      str/re-quote-replacement: code

# vim: ft=yaml:
