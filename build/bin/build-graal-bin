#!/usr/bin/env bash

source "$(dirname "$0")/init.bash"

main() (
  gen-project-clj |& build-log
  gen-src-main-file-clj |& build-log

  log "Building yamlscript.core jar..."
  build-jar |& build-log

  log 'Building the GraalVM native-image binary executable...'
  log 'This may take a few minutes. Steps 2 and 6 take the most time.'

  build-native-image |& tee -a $build_log |
    (
      if [[ ${YS_BUILD_DEBUG-} ]]; then
        cat
      else
        grep -E '^\[' || true
      fi
    )
)

gen-project-clj() (
  cp share/graal-project.clj project.clj
)

gen-src-main-file-clj() (
  mkdir -p src
  "$wrap_bin" "$input_path" share/$build_type.clj \
    > src/main_file.clj
)

build-jar() (
  make -C "$ROOT/core" install
    lein deps
    lein uberjar
)

build-native-image() (
  native-image \
    $native_options \
    -jar $ys_jar_file \
    -o "$output_path"
)

main "$@"
