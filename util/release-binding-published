#!/usr/bin/env bash

set -euo pipefail

binding=${1:?Usage: release-binding-published <binding> <version>}
version=${2:?Usage: release-binding-published <binding> <version>}

quiet=${YS_RELEASE_PUBLISHED_QUIET:-}

log() {
  [[ $quiet ]] || echo "$@"
}

url-exists() {
  curl -A yamlscript-release -fsIL "$1" >/dev/null 2>&1
}

json-url-exists() {
  curl -A yamlscript-release -fsL "$1" >/dev/null 2>&1
}

julia-version-exists() {
  local url
  url='https://raw.githubusercontent.com/JuliaRegistries/General/master'
  url="$url/Y/YAMLScript/Versions.toml"
  curl -A yamlscript-release -fsL "$url" |
    grep -Fq "[\"$version\"]"
}

cpan-package-exists() {
  local package=$1
  local cpan_version
  local url='https://www.cpan.org/modules/02packages.details.txt.gz'
  cpan_version=$(perl-cpan-version)
  curl -A yamlscript-release -fsL "$url" |
    gzip -dc |
    awk \
      -v package="$package" \
      -v version="$version" \
      -v cpan_version="$cpan_version" '
      $1 == package && ($2 == version || $2 == cpan_version) { found = 1 }
      END { exit found ? 0 : 1 }
    '
}

pause-dist-verified() {
  local dist=$1
  local path="I/IN/INGY/$dist-$version.tar.gz"
  local url='https://pause.perl.org/pause/authenquery?ACTION=tail_logfile'
  [[ ${PAUSE_USER:-} && ${PAUSE_PASS:-} ]] || return 1
  curl -A yamlscript-release -fsL -u "$PAUSE_USER:$PAUSE_PASS" "$url" |
    grep -Fq "Verified $path"
}

perl-cpan-version() {
  awk -v version="$version" '
    BEGIN {
      n = split(version, part, ".")
      if (n == 3 && part[1] ~ /^[0-9]+$/ &&
          part[2] ~ /^[0-9]+$/ && part[3] ~ /^[0-9]+$/) {
        printf "%d.%03d%03d\n", part[1], part[2], part[3]
        exit
      }
      print version
    }
  '
}

git-tag-exists() {
  git ls-remote --exit-code --tags "$1" "refs/tags/$2" \
    >/dev/null 2>&1
}

haskell-version() {
  case $version in
    *.*.*.*) printf '%s\n' "$version" ;;
    *) printf '%s.0\n' "$version" ;;
  esac
}

published=false

case $binding in
  java)
    url='https://repo.clojars.org/org/yamlscript/yamlscript'
    url-exists "$url/$version/yamlscript-$version.jar" &&
      published=true
    ;;
  clojure)
    url='https://repo.clojars.org/org/yamlscript/clj-yamlscript'
    url-exists "$url/$version/clj-yamlscript-$version.jar" &&
      published=true
    ;;
  csharp)
    lower_version=$(printf '%s' "$version" | tr '[:upper:]' '[:lower:]')
    url='https://api.nuget.org/v3-flatcontainer/yamlscript'
    url-exists "$url/$lower_version/yamlscript.$lower_version.nupkg" &&
      published=true
    ;;
  go)
    git-tag-exists https://github.com/yaml/yamlscript-go "v$version" &&
      published=true
    ;;
  haskell)
    hversion=$(haskell-version)
    url-exists "https://hackage.haskell.org/package/yamlscript-$hversion" &&
      published=true
    ;;
  nodejs)
    export NPM_CONFIG_CACHE="${NPM_CONFIG_CACHE:-.cache/npm}"
    npm view "@yaml/yamlscript@$version" version >/dev/null 2>&1 &&
      published=true
    ;;
  lua)
    url='https://luarocks.org/modules/ingy/yamlscript'
    url-exists "$url/$version-1" &&
      published=true
    ;;
  julia)
    julia-version-exists &&
      published=true
    ;;
  python)
    json-url-exists "https://pypi.org/pypi/yamlscript/$version/json" &&
      published=true
    ;;
  ruby)
    url="https://rubygems.org/api/v2/rubygems/yamlscript/versions"
    json-url-exists "$url/$version.json" &&
      published=true
    ;;
  rust)
    json-url-exists "https://crates.io/api/v1/crates/yamlscript/$version" &&
      published=true
    ;;
  crystal|php)
    git-tag-exists "https://github.com/yaml/yamlscript-$binding" \
      "v$version" &&
      published=true
    ;;
  perl)
    if pause-dist-verified YAMLScript ||
        cpan-package-exists YAMLScript; then
      published=true
    fi
    ;;
  perl-alien)
    if pause-dist-verified Alien-YAMLScript ||
        cpan-package-exists Alien::YAMLScript; then
      published=true
    fi
    ;;
  raku)
    log "No published check for binding: $binding"
    exit 1
    ;;
  *)
    log "No published check for binding: $binding"
    exit 1
    ;;
esac

if $published; then
  log "$binding $version is already published"
  exit 0
fi

log "$binding $version is not published"
exit 1
