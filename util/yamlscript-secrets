#!/usr/bin/env ys-0

# Manage the YAMLScript release publishing credentials.
#
# Credentials live in ~/.yamlscript-secrets.yaml, keyed by binding. Each
# entry names the registry it publishes to via 'uses', plus the field
# values and (optionally) a rotation schedule, e.g.:
#
#   nodejs:
#     uses: npm
#     token: npm_xxxxx
#     time: 2025-12-24 00:00:00
#     days: 90
#   perl:
#     uses: pause
#     user: ingy
#     pass: xxxxx
#   raku:
#     uses: fez
#     user: ingy
#     token: xxxxx
#   ssh:
#     priv: /home/ingy/.ssh/yamlscript-release-ed25519
#
# The 'uses' value selects a registry definition below, which maps the
# entry's fields to GitHub secret names and knows how to obtain a token.
# 'also' (e.g. clojure -> also: java) just records a binding that shares
# the same credentials. github has no 'uses'; its token publishes as
# JULIA_GITHUB_TOKEN (Julia registration needs a real user PAT) and is
# also used as GH_TOKEN for `gh secret set`.
#
# A binding is "due" when a value is missing, or time + days has passed.
# Entries with values but no time/days are treated as manual (not auto-
# refreshed) but are still published. File-valued fields, such as ssh.priv,
# publish the contents of the named file.
#
# Usage:
#   yamlscript-secrets --update=all          # refresh due bindings
#   yamlscript-secrets --update=nodejs,clojure # force-refresh listed
#   yamlscript-secrets --list                # show status (masked)
#   yamlscript-secrets --publish             # push all to GitHub secrets
#
# Environment variables:
#   YS_SECRETS_FILE      - override the secrets file path (for testing)
#   YS_RELEASE_DRYRUN=1  - don't run mutating commands, just show them

repo =: 'yaml/yamlscript'
dryrun =: B(ENV.YS_RELEASE_DRYRUN)
default-days =: 90

# Registry definitions, keyed by the binding's 'uses' value (github is
# keyed by itself). Each maps fields to GitHub secret names and may carry
# acquisition helpers:
#   login - interactive CLI that authenticates (run with terminal IO)
#   fetch - shell snippet that reads the stored token after login
#   url   - token-creation page to print when a paste is needed
#   hint  - custom instruction (overrides the url line)
registries =::
  github:
    hint: |-
      Paste a classic GitHub PAT with the 'repo' scope, created at
      https://github.com/settings/tokens. It is used as GH_TOKEN and
      published as the JULIA_GITHUB_TOKEN secret.
    fields:
    - name: token
      secret: JULIA_GITHUB_TOKEN
  clojars:
    url: https://clojars.org/tokens
    fields:
    - name: user
      secret: CLOJARS_USERNAME
    - name: token
      secret: CLOJARS_PASSWORD
  crates:
    url: https://crates.io/settings/tokens
    fetch: |-
      sed -n 's/^token = "\(.*\)"/\1/p' ~/.cargo/credentials.toml 2>/dev/null
    fields:
    - name: token
      secret: CRATES_TOKEN
  fez:
    login: fez login
    fetch: |-
      ys -le '.key:say' ~/.fez-config.json 2>/dev/null
    hint: |-
      Raku/zef has no token web page. Run `fez login`, then paste the
      'un' and 'key' values saved in ~/.fez-config.json.
    fields:
    - name: user
      secret: FEZ_USER
    - name: token
      secret: FEZ_TOKEN
  hackage:
    url: https://hackage.haskell.org/users/account-management
    fields:
    - name: token
      secret: HACKAGE_TOKEN
  luarocks:
    url: https://luarocks.org/settings/api-keys
    fields:
    - name: token
      secret: LUAROCKS_API_KEY
  npm:
    hint: |-
      Create a granular access token at
      https://www.npmjs.com/settings/ingy/tokens.
      Scope it to the @yaml/yamlscript package.
      Give it read/write or publish access.
      Enable bypass 2FA so GitHub Actions can publish with it.
    fields:
    - name: token
      secret: NPM_TOKEN
  nuget:
    url: https://www.nuget.org/account/apikeys
    fields:
    - name: token
      secret: NUGET_API_KEY
  packagist:
    url: https://packagist.org/profile
    fields:
    - name: user
      secret: PACKAGIST_USER
    - name: token
      secret: PACKAGIST_TOKEN
  pause:
    hint: |-
      CPAN/PAUSE credentials for perl and perl-alien. Maintained by
      hand; enter your PAUSE user and password.
    fields:
    - name: user
      secret: PAUSE_USER
    - name: pass
      secret: PAUSE_PASS
  pypi:
    url: https://pypi.org/manage/account/token
    fields:
    - name: token
      secret: PYPI_API_TOKEN
  rubygems:
    url: https://rubygems.org/profile/api_keys
    fetch: |-
      sed -n 's/^:rubygems_api_key: //p' ~/.gem/credentials 2>/dev/null
    fields:
    - name: token
      secret: RUBYGEMS_API_KEY
  ssh:
    hint: |-
      Path to the private SSH key that can push to the YAMLScript mirror
      repositories. The file contents publish as BINDING_REPO_SSH_KEY.
    fields:
    - name: priv
      secret: BINDING_REPO_SSH_KEY
      file: true


defn main(*args):
  when-not args.?:
    usage:
    exit: 0

  each arg args:
    handle-arg: arg


defn handle-arg(arg):
  cond:
    arg.starts?('--update='): do-update(subs(arg 9))
    arg == '--publish'      : do-publish()
    arg == '--list'         : do-list()
    arg.in?(["--help" "-h"]): usage()
    else:
      die: "Unknown option: $arg\nRun 'yamlscript-secrets --help'."


#------------------------------------------------------------------------------
# Commands
#------------------------------------------------------------------------------

defn do-update(spec):
  forced =: spec != 'all'
  state =: atom(load-secrets())
  targets =:
    if forced:
      then: parse-bindings(state.@ spec)
      else: binding-keys(state.@)

  each b targets:
    reg =: registry-for(state.@ b)
    entry =: state.@.get(b) || {}
    if forced || due?(entry reg):
      then:
        updated =: update-binding(state.@ b reg)
        reset state: updated
        save-secrets: updated
      else:
        say: "== $b == $(status-line(entry reg))"

  say: "\n✓ Update complete"


defn do-list():
  data =: load-secrets()

  say: "Release credentials in $(secrets-file()):\n"

  each b binding-keys(data):
    list-binding: data b


defn list-binding(data b):
  reg =: registry-for(data b)
  entry =: data.get(b) || {}
  hdr =: entry.also.if("$b (also $(entry.also))" b)
  say: "== $hdr =="
  each field reg.fields:
    val =: entry.get(field.name)
    status =: empty?(val).if('MISSING' mask(val))
    say: "  $(rpad(field.secret 22)) $status"
  say: "  $(status-line(entry reg))"


defn do-publish():
  data =: load-secrets()
  env =: gh-env(data)
  pushed =: atom(0)
  failed =: atom([])
  missing =: atom([])

  say: "Publishing secrets to $repo:\n"

  each b binding-keys(data):
    reg =: registry-for(data b)
    entry =: data.get(b) || {}
    each field reg.fields:
      publish-secret: field entry.get(field.name) env pushed failed missing

  say: "\n✓ Published $(pushed.@) secret(s)"
  when-not empty?(failed.@):
    say: "  Failed: $(failed.@.join(', '))"
  when-not empty?(missing.@):
    say: "  Missing (not in file): $(missing.@.join(', '))"


defn publish-secret(field val env pushed failed missing):
  name =: field.secret
  cond:
    empty?(val):
      swap missing: \(_.conj(name))
    field.file && not(fs-e(val)):
      do:
        warn: "  ✗ missing file for $name: $val"
        swap failed: \(_.conj(name))
    else:
      secret =: field.file.if(read(val) val)
      if publish-one(name secret env):
        then:
          swap pushed: inc
        else:
          swap failed: \(_.conj(name))


#------------------------------------------------------------------------------
# Update helpers
#------------------------------------------------------------------------------

defn update-binding(data b reg):
  say: "\n== $b =="
  show-hint: reg
  entry =: data.get(b) || {}
  changed =: atom(false)
  logged-in =: atom(false)

  updated =:
    reduce _ entry reg.fields:
      fn(e field):
        val =: acquire-field(reg field e.get(field.name) logged-in)
        if empty?(val):
          then: e
          else:
            reset changed: true
            e: .assoc(field.name val)

  if changed.@:
    then:
      days =: entry.get('days') || default-days
      stamped =: updated.assoc('time' now()).assoc('days' days)
      data: .assoc(b stamped)
    else: data


defn show-hint(reg):
  url-note =: reg.url && "Create a token at $(reg.url)"
  note =: reg.hint || url-note
  when note:
    each line note:lines:
      say: "  $line"


defn acquire-field(reg field current logged-in):
  if field.name == 'token':
    then: acquire-token(reg current logged-in)
    else: prompt-field(field current)


defn acquire-token(reg current logged-in):
  fetched =: fetch-after-login(reg logged-in)
  if fetched.?:
    do:
      say: "  got token via login"
      =>: fetched
    else: prompt-token(current)


defn fetch-after-login(reg logged-in):
  if reg.fetch.!:
    then: ''
    else:
      need-login =: reg.login && not(logged-in.@)
      when need-login:
        say: "  Logging in (follow the prompts)..."
        try-login: reg.login
        reset logged-in: true
      try-fetch: reg.fetch


defn prompt-field(field current):
  note =: empty?(current).if('blank to skip' 'blank to keep')
  print: "  $(field.secret) ($note): "
  trim: read-line() || ''


defn prompt-token(current):
  note =: empty?(current).if('blank to skip' 'blank to keep')
  print: "  paste token ($note): "
  trim: read-line() || ''


defn try-login(cmd):
  try:
    shell: cmd
    catch Exception e:
      warn: "  login command failed: $(e:str)"


defn try-fetch(cmd):
  try:
    do:
      result =: bash(cmd)
      if result.exit == 0:
        =>: result.out:trim
        =>: ''
    catch Exception e:
      =>: ''


#------------------------------------------------------------------------------
# Publish helpers
#------------------------------------------------------------------------------

defn publish-one(name val env):
  if dryrun:
    then:
      say: "+ gh secret set $name --repo $repo  (value: $(mask val))"
      =>: true
    else:
      # gh reads the secret value from stdin when --body is omitted
      result =:
        sh {:in val, :extra-env env}:
          "gh secret set $name --repo $repo"
      if result.exit == 0:
        then:
          say: "  ✓ set $name"
          =>: true
        else:
          warn: "  ✗ failed $name: $(result.err:trim)"
          =>: false


#------------------------------------------------------------------------------
# Binding / registry resolution
#------------------------------------------------------------------------------

defn registry-for(data b):
  entry =: data.get(b) || {}
  registries: .get(entry.uses || b)


defn binding-keys(data):
  keys(data).filter(\(registry-for(data _)))


defn parse-bindings(data spec):
  spec.split(/,/).map(\(check-binding(data trim(_))))


defn check-binding(data b):
  when-not b.in?(binding-keys(data)):
    die: "Unknown binding: $b\nKnown: $(binding-keys(data).join(', '))"
  =>: b


#------------------------------------------------------------------------------
# Expiry helpers
#------------------------------------------------------------------------------

defn time-of(entry):
  t =: entry.get('time')
  when-not nil?(t):
    str: t


defn incomplete?(entry reg):
  reg.fields.some(\(empty?(entry.get(_.name))))


defn due?(entry reg):
  time =: time-of(entry)
  days =: entry.get('days')
  cond:
    incomplete?(entry reg): true
    nil?(time) || nil?(days): false
    else: due-epoch(time days) <= now-epoch()


defn due-epoch(time days):
  base =: sh-out("date -d '$time' +%s"):N
  base +: days * 86400


defn now-epoch():
  sh-out('date +%s'):N


defn rotate-by(entry):
  time =: time-of(entry)
  days =: entry.get('days')
  if nil?(time) || nil?(days):
    then: 'now'
    else:
      ts =: due-epoch(time days)
      sh-out: "date -d '@$ts' '+%Y-%m-%d'"


defn status-line(entry reg):
  cond:
    incomplete?(entry reg): 'incomplete (run --update)'
    nil?(entry.get('time')) || nil?(entry.get('days')):
      'set (manual, no rotation)'
    due?(entry reg): "DUE (rotate by $(rotate-by(entry)))"
    else: "ok (rotate by $(rotate-by(entry)))"


#------------------------------------------------------------------------------
# Storage helpers
#------------------------------------------------------------------------------

defn secrets-file():
  ENV.YS_SECRETS_FILE || "$(ENV.HOME)/.yamlscript-secrets.yaml"


defn load-secrets():
  file =: secrets-file()
  if fs-e(file):
    then: yaml/load(read(file)) || {}
    else: +{}


defn save-secrets(data):
  file =: secrets-file()
  write file: yaml/dump(data)
  bash: "chmod 600 '$file'"


defn gh-env(data):
  token =: data.get-in(['github' 'token'])
  if token.?:
    =>: +{"GH_TOKEN" token}
    =>: +{}


defn now():
  sh-out: "date '+%Y-%m-%d %H:%M:%S'"


#------------------------------------------------------------------------------
# Formatting helpers
#------------------------------------------------------------------------------

defn mask(val):
  cond:
    empty?(val)   : '(none)'
    count(val) > 4: "****$(subs(val (count(val) - 4)))"
    else          : '****'


defn ok(result): result.exit == 0

defn rpad(s n):
  pad =: n - count(s)
  if pad > 0:
    s +: pad * ' '
    else: s


defn usage():
  say: |
    yamlscript-secrets - manage release publishing credentials

    Usage:
      yamlscript-secrets --update=all          Refresh due bindings
      yamlscript-secrets --update=nodejs,clojure Force-refresh listed
      yamlscript-secrets --list                Show status (masked)
      yamlscript-secrets --publish             Push all to GitHub secrets

    Credentials live in ~/.yamlscript-secrets.yaml (override with
    YS_SECRETS_FILE). Set YS_RELEASE_DRYRUN=1 to preview --publish.
